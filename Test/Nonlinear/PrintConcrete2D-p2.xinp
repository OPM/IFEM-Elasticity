<?xml version="1.0" encoding="UTF-8" standalone="yes"?>

<simulation>

  <geometry dim="2" Lx="2" Ly="3">
    <raiseorder patch="1" u="1" v="1"/>
    <refine patch="1" u="3" v="4"/>
    <topologysets>
      <set name="fixedY" type="edge">
        <item patch="1">3</item>
      </set>
      <set name="fixedX" type="point">
        <item patch="1">1</item>
      </set>
    </topologysets>
    <activation patch="1">20.0*t</activation>
  </geometry>

  <boundaryconditions>
    <dirichlet set="fixedX" comp="1"/>
    <dirichlet set="fixedY" comp="2"/>
  </boundaryconditions>

  <finitedeformation>
    <formulation>
      <updatedlagrange/>
    </formulation>
    <gravity y="-9.81"/>
    <druckerprager E="1.4e6" nu="0.3" rho="2070" beta="35">
      <stiffness aging="true" type="piecewiselinear">Betong.dat 2</stiffness>
      <yieldlimit version="A" beta="35" type="piecewiselinear">Betong.dat 3</yieldlimit>
    </druckerprager>
  </finitedeformation>

  <discretization>
    <nGauss>3 4</nGauss>
  </discretization>

  <timestepping>
    <step start="0.0" end="400">40</step>
  </timestepping>

  <linearsolver>
    <class fixzeros="true"/>
  </linearsolver>

  <nonlinearsolver>
    <updateNewNodes/>
  </nonlinearsolver>

  <postprocessing>
    <vtfformat>BINARY</vtfformat>
    <direct2nd/>
  </postprocessing>

</simulation>
