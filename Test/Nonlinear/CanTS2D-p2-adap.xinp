<?xml version="1.0" encoding="UTF-8" standalone="yes"?>

<!-- 2D Cantilever beam with a tip shear load. Adaptive simulation. !-->

<simulation>

  <geometry dim="2" Lx="2.0" Ly="0.4">
    <raiseorder patch="1" u="1" v="1"/>
    <refine patch="1" u="7" v="1"/>
    <topologysets>
      <set name="fixed_corner" type="vertex">
        <item patch="1">1 3</item>
      </set>
      <set name="fixed_end" type="edge">
        <item patch="1">1</item>
      </set>
      <set name="free_end" type="edge">
        <item patch="1">2</item>
      </set>
    </topologysets>
  </geometry>

  <boundaryconditions>
    <dirichlet comp="1" set="fixed_end"/>
    <dirichlet comp="2" set="fixed_corner"/>
    <neumann set="free_end" direction="2" type="expression">
      L=2; H=0.4; I=H*H*H/12; Y=y/H-0.5;
      F0=-1000000*sin(3.14159265*t);
     -F0*(H*H/I)*(0.5-x/L)*(0.25-Y*Y)
    </neumann>
  </boundaryconditions>

  <elasticity>
    <isotropic E="2.068e9" nu="0.29" rho="7820.0"/>
  </elasticity>

  <discretization>
    <nGauss>3 4</nGauss>
  </discretization>

  <nonlinearsolver>
    <rtol>1.0e-8</rtol>
    <timestepping>
      <step start="0.0" end="0.5">0.05</step>
    </timestepping>
  </nonlinearsolver>

  <postprocessing>
    <projection type="cgl2"/>
  </postprocessing>

  <adaptive>
    <scheme>isotropic_function</scheme>
    <beta type="symmetrized">5.0</beta>
    <errtol>1.0</errtol>
    <maxdof>100000</maxdof>
    <maxstep>15</maxstep>
  </adaptive>

</simulation>
