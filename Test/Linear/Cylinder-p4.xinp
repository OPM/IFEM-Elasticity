<?xml version="1.0" encoding="UTF-8" standalone="yes"?>

<!-- Thick cylinder with internal pressure.
     Static linear-elastic analysis, quartic NURBS elements. !-->

<simulation>

  <geometry dim="3">
    <patchfile>cylinder.g2</patchfile>
    <topologysets>
      <set name="internal" type="face">
        <item patch="1">3</item>
      </set>
      <set name="ends" type="face">
        <item patch="1">5 6</item>
      </set>
      <set name="P1" type="vertex">
        <item patch="1">1</item>
      </set>
      <set name="P2" type="vertex">
        <item patch="1">3</item>
      </set>
    </topologysets>
    <periodic patch="1" dir="1"/>
  </geometry>

  <boundaryconditions>
    <dirichlet set="ends" comp="3"/>
    <dirichlet set="P1" comp="123"/>
    <dirichlet set="P2" comp="23"/>
    <neumann set="internal" direction="0">-1.0e6</neumann>
  </boundaryconditions>

  <localsystem>cylindricz</localsystem>

</simulation>
