<?xml version="1.0" encoding="UTF-8" standalone="yes"?>

<!-- Simply supported rectangular plate with partial pressure load.
     Quadratic spline Kirchhoff-Love thin plate elements. !-->

<simulation>

  <!-- General - geometry definitions !-->
  <geometry dim="2">
    <patch>
      200 1 0 0 2 0\
      3 3 0 0 0 1 1 1\
      3 3 0 0 0 1 1 1\
      0 0 5 0 10 0\
      0 4 5 4 10 4\
      0 8 5 8 10 8\
    </patch>
    <refine patch="1" u="4" v="4"/>
    <topologysets>
      <set name="boundary" type="edge">
        <item patch="1">1 2 3 4</item>
      </set>
      <set name="plate" type="face">
        <item patch="1"/>
      </set>
    </topologysets>
  </geometry>

  <!-- General - boundary conditions !-->
  <boundaryconditions>
    <dirichlet set="boundary" comp="1"/>
  </boundaryconditions>

  <!-- Problem specific block !-->
  <kirchhofflove>
    <isotropic E="2.1e11" nu="0.3" rho="1.0e3" thickness="0.1"/>
    <pressure set="plate" type="StepXY">1.0e3 4.0 3.2 to 6.0 4.8</pressure>
    <anasol type="NavierPlate" a="10.0" b="8.0" c="2.0" d="1.6" xi="0.5" eta="0.5" pz="1.0e3"/>
  </kirchhofflove>

  <!-- General - Gauss quadrature scheme !-->
  <discretization>
    <nGauss>2</nGauss>
  </discretization>

  <!-- General - result output !-->
  <postprocessing>
    <projection>
      <global/>
    </projection>
    <resultpoints>
      <point patch="1" u="0.5" v="0.5"/>
    </resultpoints>
  </postprocessing>

</simulation>
